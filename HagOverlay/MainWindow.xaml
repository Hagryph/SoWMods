<Window x:Class="HagOverlay.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="HagUI Overlay"
        WindowStyle="None" ResizeMode="NoResize" ShowInTaskbar="False"
        ShowActivated="False"
        Topmost="True" WindowStartupLocation="Manual"
        Left="0" Top="0" Width="200" Height="200"
        Background="#0A0A0C">
    <!-- Full-modal hub: the window covers the game's client area; the CSS backdrop is opaque, so
         it blocks click-through entirely. Opaque window avoids WebView2/WPF transparency airspace. -->
    <wv2:WebView2 x:Name="Web"/>
</Window>
